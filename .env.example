# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== LLM 配置 ====================
# LLM API 密钥（必需）
LLM_API_KEY=your-llm-api-key-here

# LLM API 地址（可选，默认为 OpenAI 兼容接口）
# LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型名称（可选，默认为 gpt-3.5-turbo）
# LLM_MODEL=gpt-3.5-turbo


# ==================== 数据库配置 ====================
# 是否启用 MySQL（可选，默认为 false）
USE_MYSQL=false

# MySQL 主机（如果启用 MySQL）
MYSQL_HOST=localhost

# MySQL 端口（如果启用 MySQL）
MYSQL_PORT=3306

# MySQL 用户（如果启用 MySQL）
MYSQL_USER=root

# MySQL 密码（如果启用 MySQL）
MYSQL_PASSWORD=your-mysql-password-here

# MySQL 数据库名（如果启用 MySQL）
MYSQL_DATABASE=video_to_action


# ==================== 认证配置 ====================
# 是否启用用户认证（可选，默认为 false）
# 设置为 true 启用 JWT Token 认证
ENABLE_AUTH=false

# JWT 密钥（生产环境必须修改）
# 建议使用强随机密钥：openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production

# JWT 算法（可选，默认为 HS256）
JWT_ALGORITHM=HS256

# Access Token 过期时间（分钟，可选，默认为 15）
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token 过期时间（天，可选，默认为 7）
REFRESH_TOKEN_EXPIRE_DAYS=7


# ==================== CORS 配置 ====================
# CORS 允许的来源（逗号分隔，可选，默认为 http://localhost:3000,http://localhost:8000）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# ==================== 其他配置 ====================
# 日志级别（可选，默认为 INFO）
# LOG_LEVEL=INFO

# 输出目录（可选，默认为 outputs）
# OUTPUT_DIR=outputs

# 数据目录（可选，默认为 data）
# DATA_DIR=data
